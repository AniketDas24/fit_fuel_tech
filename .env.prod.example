# PRODUCTION secrets. Copy this file to .env.prod and fill in real values.
# .env.prod is gitignored — never commit real secrets. Loaded by run-prod.sh.
# The prod profile REQUIRES every value here: a missing one stops the boot.

# --- Database (a real PostgreSQL instance) ---
DATABASE_URL=jdbc:postgresql://<host>:5432/fitfuel
DATABASE_USERNAME=fitfuel
DATABASE_PASSWORD=

# --- Auth --- generate a long random string, e.g. `openssl rand -base64 48`
JWT_SECRET=

# --- Razorpay LIVE keys (real money) --- Dashboard in Live Mode -> Settings -> API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret you set when creating the webhook (Dashboard -> Settings -> Webhooks).
# Point the webhook at https://<your-backend>/payments/webhook and subscribe to
# "payment.captured" and "order.paid". Leave blank to disable webhook handling.
RAZORPAY_WEBHOOK_SECRET=

# --- Twilio WhatsApp (production, via a verified WhatsApp Business Account) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your approved WhatsApp Business sender number (NOT the sandbox number).
TWILIO_WHATSAPP_FROM=
# Meta-approved Content Template SID (starts with HX...). Required in production —
# free-text business-initiated messages are rejected by Meta. Register a utility
# template whose body is e.g. "FitFuel order update: {{1}}".
TWILIO_WHATSAPP_CONTENT_SID=
