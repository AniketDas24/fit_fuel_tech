# LOCAL / development secrets. Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets. Loaded automatically by run-local.sh.
# (The local profile supplies the datasource + JWT secret itself, so only the
# third-party sandbox credentials belong here.)

# Razorpay TEST-mode keys: Dashboard -> Settings -> API Keys (make sure "Test Mode" is on).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio: Console dashboard for Account SID / Auth Token.
# TWILIO_WHATSAPP_FROM is the shared WhatsApp Sandbox number (+14155238886), shown under
# Messaging -> Try it out -> Send a WhatsApp message.
# Each recipient phone must WhatsApp the sandbox's "join <code>" message once before it can
# receive anything, and the join expires after ~3 days of inactivity.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
# Leave blank locally to send free-text sandbox messages. (Production uses a template — see .env.prod.example.)
TWILIO_WHATSAPP_CONTENT_SID=
